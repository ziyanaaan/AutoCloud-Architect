# Environment Variables

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# SageMaker Configuration
SAGEMAKER_ENDPOINT_NAME=autocloud-recommender
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/SageMakerExecutionRole

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# S3 Configuration
S3_DEPLOYMENT_BUCKET=autocloud-deployments

# Database (optional - for job tracking)
DATABASE_URL=sqlite:///./autocloud.db
